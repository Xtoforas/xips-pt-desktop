{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "xips-pt desktop",
  "version": "0.1.0",
  "identifier": "com.xips.desktop",
  "build": {
    "beforeDevCommand": "npm --prefix .. run dev -- --host 0.0.0.0 --port 1420",
    "beforeBuildCommand": "npm --prefix .. run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "xips-pt desktop",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
